{
  "compilerOptions": {
    /* Project structure */
    "outDir": "./dist",

    /* Module system */
    "module": "commonjs",
    "target": "es2020",
    "moduleResolution": "node",

    /* Node environment */
    "lib": ["es2020"],
    "types": ["node"],

    /* Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Output */
    "sourceMap": true,

    /* Type checking */
    "strict": true,
    "skipLibCheck": true,

    /* Consistency */
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}